HOMEPAGE="https://gitlab.com/mnauw/${PN}"
GIT_URI="https://gitlab.com/mnauw/${PN}.git"
GIT_TAG="v${PV}"

CATEGORY="Devel"
SUMMARY="GObject-Introspection C++ binding wrapper generator"
DESCRIPTION="${SUMMARY}"

LICENSE="MIT"
