+#include <string>
+// On GCC without C++11 ABI (e.g. Cygwin), <string> does not define std::pmr::string
+// because the pmr section is guarded by _GLIBCXX_USE_CXX11_ABI. Provide the aliases
+// explicitly using polymorphic_allocator from <memory_resource>.
+#if defined(__GLIBCXX__) && !_GLIBCXX_USE_CXX11_ABI
+namespace std { namespace pmr {
+    using string    = basic_string<char, char_traits<char>, polymorphic_allocator<char>>;
+    using wstring   = basic_string<wchar_t, char_traits<wchar_t>, polymorphic_allocator<wchar_t>>;
+    using u16string = basic_string<char16_t, char_traits<char16_t>, polymorphic_allocator<char16_t>>;
+    using u32string = basic_string<char32_t, char_traits<char32_t>, polymorphic_allocator<char32_t>>;
+} }
+#endif
 #else
 #warning "Old compiler missing memory_resource support."
