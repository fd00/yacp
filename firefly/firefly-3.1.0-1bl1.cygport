HOMEPAGE="https://github.com/tbhaxor/${PN}"
SRC_URI="https://github.com/tbhaxor/${PN}/archive/refs/tags/v${PV}.tar.gz"

CATEGORY="Libs"
SUMMARY="Standalone C++ Library for vectors calculations"
DESCRIPTION="${SUMMARY}"

LICENSE="GPL-3.0-or-later"
LICENSE_SPDX="SPDX-License-Identifier: GPL-3.0-or-later"
LICENSE_URI="LICENSE"

BUILD_REQUIRES="
	libgtest-devel
"

inherit cmake

CYGCMAKE_ARGS="
	-DFirefly_ENABLE_EXAMPLES:BOOL=ON
	-DFirefly_ENABLE_TESTS:BOOL=ON
"
