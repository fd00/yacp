HOMEPAGE="https://github.com/sjmulder/${PN}"
SRC_URI="https://github.com/sjmulder/${PN}/archive/refs/tags/${PV}.tar.gz"

CATEGORY="Utils"
SUMMARY="Split separated input into files"
DESCRIPTION="${SUMMARY}"

LICENSE="BSD-2-Clause"
LICENSE_SPDX="SPDX-License-Identifier: BSD-2-Clause"
LICENSE_URI="LICENSE.md"

src_compile()
{
	cd ${B}
	lndirs
	cygmake PREFIX=/usr MANPREFIX=/usr/share/man
}

src_install()
{
	cd ${B}
	dobin ${PN}.exe
	doman ${PN}.1
}

DOCS="
	CHANGELOG.md
"
