--- origsrc/jsonnet-0.21.0/core/CMakeLists.txt	2025-05-07 21:28:56.000000000 +0900
+++ src/jsonnet-0.21.0/core/CMakeLists.txt	2026-03-20 20:57:30.433834000 +0900
@@ -54,6 +54,11 @@ install(TARGETS libjsonnet
 target_include_directories(libjsonnet INTERFACE
   $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/../include>)
 
+# pkg-config file
+configure_file(jsonnet.pc.in jsonnet.pc @ONLY)
+install(FILES "${CMAKE_CURRENT_BINARY_DIR}/jsonnet.pc"
+    DESTINATION "${CMAKE_INSTALL_LIBDIR}/pkgconfig")
+
 if (BUILD_STATIC_LIBS)
     # Static library for jsonnet command-line tool.
     add_library(libjsonnet_static STATIC ${LIBJSONNET_SOURCE})
--- origsrc/jsonnet-0.21.0/core/jsonnet.pc.in	1970-01-01 09:00:00.000000000 +0900
