@@ -0,0 +1,10 @@
+prefix=@CMAKE_INSTALL_PREFIX@
+exec_prefix=${prefix}
+libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
+includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@
+
+Name: libjsonnet
+Description: C API for Jsonnet - The data templating language
+Version: @JSONNET_VERSION@
+Libs: -L${libdir} -ljsonnet
+Cflags: -I${includedir}
