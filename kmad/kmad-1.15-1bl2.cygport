HOMEPAGE="https://github.com/cmbi/${PN}"
SRC_URI="https://github.com/cmbi/${PN}/archive/refs/tags/v${PV}.tar.gz"

CATEGORY="Science"
SUMMARY="Knowledge based multiple sequence alignment for intrinsically disordered proteins"
DESCRIPTION="${SUMMARY}"

LICENSE="GPL-3.0-or-later"
LICENSE_SPDX="SPDX-License-Identifier: GPL-3.0-or-later"
LICENSE_URI="COPYING"

BUILD_REQUIRES="
	libboost-devel
	libconfig++-devel
"

CYGCONF_ARGS="
	--includedir=/usr/include/${PN}
"
