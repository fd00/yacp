--- origsrc/microtar-0.1.0/CMakeLists.txt	1970-01-01 09:00:00.000000000 +0900
+++ src/microtar-0.1.0/CMakeLists.txt	2026-05-30 12:23:19.793853100 +0900
@@ -0,0 +1,25 @@
+cmake_minimum_required(VERSION 3.28)
+project(microtar
+  VERSION 0.1.0
+  DESCRIPTION "Lightweight tar library written in ANSI C"
+  HOMEPAGE_URL "https://github.com/rxi/microtar")
+
+include(GNUInstallDirs)
+include(CTest)
+
+file(GLOB_RECURSE LIB_SOURCES "src/*.c")
+add_library(microtar SHARED "${LIB_SOURCES}")
+set_target_properties(microtar PROPERTIES SOVERSION 0)
+
+install(TARGETS microtar
+  RUNTIME DESTINATION ${CMAKE_INSTALL_BINDIR}
+  ARCHIVE DESTINATION ${CMAKE_INSTALL_LIBDIR})
+
+install(FILES src/microtar.h DESTINATION ${CMAKE_INSTALL_INCLUDEDIR})
+
+set(prefix ${CMAKE_INSTALL_PREFIX})
+set(exec_prefix ${CMAKE_INSTALL_PREFIX})
+set(libdir ${CMAKE_INSTALL_PREFIX}/lib)
+set(includedir ${CMAKE_INSTALL_PREFIX}/include)
+configure_file(${CMAKE_SOURCE_DIR}/microtar.pc.in ${CMAKE_BINARY_DIR}/microtar.pc @ONLY)
+install(FILES ${CMAKE_BINARY_DIR}/microtar.pc DESTINATION ${CMAKE_INSTALL_PREFIX}/lib/pkgconfig)
--- origsrc/microtar-0.1.0/microtar.pc.in	1970-01-01 09:00:00.000000000 +0900
+++ src/microtar-0.1.0/microtar.pc.in	2026-05-30 12:23:28.018183800 +0900
@@ -0,0 +1,10 @@
+prefix=@prefix@
+exec_prefix=@exec_prefix@
+libdir=@libdir@
+includedir=@includedir@
+
+Name: microtar
+Description: Lightweight tar library written in ANSI C
+Version: @PROJECT_VERSION@
+Libs: -L${libdir} -lmicrotar
+Cflags: -I${includedir}
