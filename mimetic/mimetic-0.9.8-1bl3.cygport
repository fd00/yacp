HOMEPAGE="https://www.codesink.org/${PN}_mime_library.html"
SRC_URI="https://www.codesink.org/download/${P}.tar.gz"
PATCH_URI="
	https://sources.debian.org/data/main/${PN:0:1}/${PN}/${PV}-13/debian/patches/signed-char.patch
	https://sources.debian.org/data/main/${PN:0:1}/${PN}/${PV}-13/debian/patches/g%2B%2B-11.patch
	https://sources.debian.org/data/main/${PN:0:1}/${PN}/${PV}-13/debian/patches/0001-Mimetic-can-t-parses-address-if-there-are-character-.patch
	https://sources.debian.org/data/main/${PN:0:1}/${PN}/${PV}-13/debian/patches/0002-Modify-wrong-memory-reference.patch
	https://sources.debian.org/data/main/${PN:0:1}/${PN}/${PV}-13/debian/patches/0003-Fix-possible-out-of-bound-when-removing-new-line-cha.patch
	https://sources.debian.org/data/main/${PN:0:1}/${PN}/${PV}-13/debian/patches/0004-Disable-default-constructor-for-MimeEntity.patch
	https://sources.debian.org/data/main/${PN:0:1}/${PN}/${PV}-13/debian/patches/0005-Fix-warnings.patch
