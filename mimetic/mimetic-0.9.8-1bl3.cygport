"

CATEGORY="Libs"
SUMMARY="Full featured C++ MIME library"
DESCRIPTION="mimetic is an Email library (MIME) written in C++ designed to be easy to use
and integrate but yet fast and efficient."

LICENSE="MIT"
LICENSE_SPDX="SPDX-License-Identifier: MIT"
LICENSE_URI="LICENSE"

PKG_NAMES="
	${PN}
	lib${PN}0
	lib${PN}-devel
"
mimetic_CONTENTS="
	usr/share
"
libmimetic0_CONTENTS="
	usr/bin/cyg*-0.dll
"
libmimetic_devel_CONTENTS="
	usr/include
	usr/lib
"
mimetic_SUMMARY="${SUMMARY} (licensing & readmes)"
libmimetic0_SUMMARY="${SUMMARY} (runtime)"
libmimetic_devel_SUMMARY="${SUMMARY} (development)"
