HOMEPAGE="https://github.com/lh3/${PN}"
SRC_URI="https://github.com/lh3/${PN}/archive/refs/tags/${PV}.tar.gz"

CATEGORY="Science"
SUMMARY="Implementation of the Pairwise Sequentially Markovian Coalescent (PSMC) model"
DESCRIPTION="${SUMMARY}"

LICENSE="MIT"
LICENSE_SPDX="SPDX-License-Identifier: MIT"
LICENSE_URI="LICENSE.txt"

BUILD_REQUIRES="
	zlib-devel
"

src_compile()
{
	cd ${B}
	lndirs
	cygmake
}

src_test()
{
	cd ${B}
	verbose ./${PN}.exe 1
}

src_install()
{
	cd ${B}
	dobin ${PN}.exe
}
