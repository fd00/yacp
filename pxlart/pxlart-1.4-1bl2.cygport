HOMEPAGE="https://github.com/mananapr/${PN}"
SRC_URI="https://github.com/mananapr/${PN}/archive/refs/tags/v${PV}.tar.gz"

CATEGORY="Graphics"
SUMMARY="Terminal pixel art creator"
DESCRIPTION="A pixel art editor for the terminal written in C."

LICENSE="MIT"
LICENSE_SPDX="SPDX-License-Identifier: MIT"
LICENSE_URI="LICENSE"

BUILD_REQUIRES="
	libncurses-devel
"

src_compile()
{
	cd ${B}
	lndirs
	cygmake LIBS=-lncursesw
}

src_install()
{
	cd ${B}
	dobin *.exe
	doman *.1
}

DOCS="
	*.png
"
