HOMEPAGE="https://git.ache.one/${PN}"
GIT_URI="https://git.ache.one/${PN}"
GIT_TAG="${PV}"

CATEGORY="Utils"
SUMMARY="Todo utility with a lot of features"
DESCRIPTION="${SUMMARY}"

LICENSE="GPL-3.0-or-later"
LICENSE_SPDX="SPDX-License-Identifier: GPL-3.0-or-later"
LICENSE_URI="LICENSE"

inherit git

src_compile()
{
	cd ${B}
	lndirs
	cygmake
}

src_install()
{
	cd ${B}
	dobin ${PN}.exe
}

DOCS="
	*.gif
	*.png
"
